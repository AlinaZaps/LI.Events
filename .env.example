# Local Postgres (see README.md — brew-installed postgresql@16)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vibe_a_ton

# HiBob — credentials live in 1Password, item: "Hackathon - LI.Events (HiBob)"
# Option A: paste username/password into your local .env.local (NEVER here)
# Option B: use 1Password CLI secret refs, e.g.
#   HIBOB_SERVICE_USER_ID=op://<vault>/Hackathon - LI.Events (HiBob)/username
#   HIBOB_API_TOKEN=op://<vault>/Hackathon - LI.Events (HiBob)/password
# and run the dev server with:  op run --env-file=.env.local -- pnpm dev
HIBOB_SERVICE_USER_ID=
HIBOB_API_TOKEN=

# Email dispatch: log (default, dev) or resend
EMAIL_MODE=log
RESEND_API_KEY=
EMAIL_FROM=events@li.finance

APP_BASE_URL=http://localhost:3000
