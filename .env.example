# Local Postgres (see README.md — brew-installed postgresql@16)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vibe_a_ton

# HiBob — paste service user ID + API token into your local .env.local (NEVER here)
HIBOB_SERVICE_USER_ID=
HIBOB_API_TOKEN=

# Email dispatch: log (default, dev) or resend
EMAIL_MODE=log
RESEND_API_KEY=
EMAIL_FROM=events@li.finance

APP_BASE_URL=http://localhost:3000
